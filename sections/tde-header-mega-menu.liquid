        { "type": "nav_item", "settings": { "label": "Travel", "col1_heading": "Travel", "col1_links": "Beauty cases | /collections/personalised-beauty-accessories\nLuggage tags | /collections/luggage-tags\nPassport holders | /collections/passport-holders\nTravel wallets | /collections/personalised-travel-wallets" } },
        { "type": "nav_item", "settings": { "label": "Gifts", "col1_heading": "By recipient", "col1_links": "For her | /collections/personalised-gifts-for-her\nFor him | /collections/personalised-gifts-for-him\nCorporate | /collections/personalised-corporate-gifts", "col2_heading": "By budget", "col2_links": "Under $100 | /collections/gifts-under-100\nGift cards | /collections/gift-cards" } },
        { "type": "nav_item", "settings": { "label": "Sale" } }
      ]
    }
  ]
}
