        { "type": "header", "content": "Column 1" },
        { "type": "text", "id": "col1_heading", "label": "Column 1 heading", "default": "By Style" },
        { "type": "textarea", "id": "col1_links", "label": "Column 1 links", "info": "One per line. Format: Link text | /collections/handle", "default": "Totes | /collections/totes\nShoulder | /collections/shoulder\nClutches | /collections/clutches" },
        { "type": "header", "content": "Column 2" },
