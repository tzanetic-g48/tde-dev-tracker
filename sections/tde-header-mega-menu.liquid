        { "type": "header", "content": "Column 3" },
        { "type": "text", "id": "col3_heading", "label": "Column 3 heading", "default": "By Edits" },
        { "type": "textarea", "id": "col3_links", "label": "Column 3 links", "info": "One per line. Format: Link text | /collections/handle" },
        { "type": "header", "content": "Hero media" },
        { "type": "image_picker", "id": "hero_image", "label": "Hero image", "info": "Recommended: square crop (600x600px)" },
